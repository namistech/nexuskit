# --- Server ---
PORT=3000
NODE_ENV=production

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://nexuskit:CHANGE_ME@postgres:5432/nexuskit
PG_POOL_MAX=10

# --- Redis / BullMQ ---
REDIS_URL=redis://redis:6379

# --- Meta / Instagram Graph API ---
# App Dashboard → Webhooks → your app secret
META_APP_SECRET=replace_with_meta_app_secret
# Any random string you choose — must match what you enter in the Meta
# webhook subscription dialog.
META_VERIFY_TOKEN=replace_with_a_random_string_you_choose
META_GRAPH_API_VERSION=v20.0

# --- Token encryption (AES-256-GCM) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace_with_32_byte_base64_key

# --- Worker tuning ---
WORKER_CONCURRENCY=5
# Meta compliance: keep this at 500-1000ms (1-2 DMs/sec) per connected account.
DM_PER_ACCOUNT_COOLDOWN_MS=700
